# Telegram Echo Bot Configuration
# Copy this file to .env and fill in your values

# Your Telegram bot token (get it from @BotFather)
# Format: 123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Webhook Configuration
# Public URL where Telegram will send updates (use ngrok for local development)
# Example: https://your-domain.com or https://abc123.ngrok.io
WEBHOOK_URL=https://your-domain.com

# Port for webhook server (8443, 443, 80, or 88 - Telegram requirement)
WEBHOOK_PORT=8443

# Webhook path (will be combined with bot token for security)
# Final webhook URL will be: WEBHOOK_URL/webhook/BOT_TOKEN
WEBHOOK_PATH=/webhook

# Google OAuth 2.0 Configuration
# Get these from Google Cloud Console after creating OAuth 2.0 credentials
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-client-secret
GOOGLE_REDIRECT_URI=https://your-domain.com/oauth/callback

# Database Configuration (Session Pooler)
DATABASE_USER=dbUser
DATABASE_PASSWORD=dbPassword
DATABASE_HOST=dbHost
DATABASE_PORT=dbPort
DATABASE_NAME=dbName

# Token Encryption
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=your-fernet-encryption-key

# Google Drive Settings
DRIVE_FOLDER_NAME=second_brain_inbox.md

# Day cutoff hour (0-23, default 0 = disabled).
# Messages received before this hour are saved to the *previous* day's file.
# Example: DAY_CUTOFF_HOUR=4 means anything sent between 00:00-03:59 goes into yesterday's file.
DAY_CUTOFF_HOUR=0