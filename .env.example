# Telegram Echo Bot Configuration
# Copy this file to .env and fill in your values

# Your Telegram bot token (get it from @BotFather)
# Format: 123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Webhook Configuration
# Public URL where Telegram will send updates (use ngrok for local development)
# Example: https://your-domain.com or https://abc123.ngrok.io
WEBHOOK_URL=https://your-domain.com

# Port for webhook server (8443, 443, 80, or 88 - Telegram requirement)
WEBHOOK_PORT=8443

# Webhook path (will be combined with bot token for security)
# Final webhook URL will be: WEBHOOK_URL/webhook/BOT_TOKEN
WEBHOOK_PATH=/webhook